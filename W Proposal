<script>
  // --- UTILS ---
  const fmt = (num) => num.toLocaleString(undefined, {maximumFractionDigits: 0});
  const fmtM = (num) => (num / 1000000).toFixed(2);
  const fmtK = (num) => (num/1000).toFixed(0) + 'k';
  
  // Safe DOM helpers
  const v = (id) => { const el = document.getElementById(id); return el ? parseFloat(el.value) : 0; };
  const setT = (id, txt) => { const el = document.getElementById(id); if(el) el.innerHTML = txt; };

  Chart.defaults.font.family = "'DM Mono', monospace";
  Chart.defaults.color = '#a09f99';
  let wfChart, sandboxChart, simCh;

  function openTab(tabId, btn) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.nav-links a').forEach(el => el.classList.remove('active'));
    const target = document.getElementById(tabId);
    if(target) target.classList.add('active');
    if(btn) btn.classList.add('active');
    
    if(tabId === 'tab3') calcWaterfall();
    if(tabId === 'tab4') calcSandbox();
    if(tabId === 'tab5') calcSim();
  }

  // --- TAB 3: WATERFALL ---
  function calcWaterfall() {
    let np = v('w-sl-np');
    let sweepPct = v('w-sl-sweep') / 100;
    let eqPct = v('w-sl-eq') / 100;
    
    setT('w-val-np', 'RM ' + fmt(np));
    setT('w-val-sweep', (sweepPct * 100) + '%');
    setT('w-val-eq', (eqPct * 100) + '%');

    let rep = np * sweepPct;
    let pool = np - rep;
    let abcDiv = pool * eqPct;
    let datoDiv = pool * (1 - eqPct);
    
    setT('w-out-rep', 'RM ' + fmt(rep));
    setT('w-out-pool', 'RM ' + fmt(pool));
    setT('w-out-abc-div', 'RM ' + fmt(abcDiv));
    setT('w-out-dato-div', 'RM ' + fmt(datoDiv));
    setT('w-out-dato-total', 'RM ' + fmt(rep + datoDiv));
    setT('w-out-dato-pct', `Takes ${(((rep + datoDiv)/np)*100).toFixed(0)}% of Total Cash`);

    if (!document.getElementById('tab3').classList.contains('active')) return;
    const ctx = document.getElementById('waterfallChart');
    if(!ctx) return;
    if(wfChart) wfChart.destroy();
    wfChart = new Chart(ctx.getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['NP Distribution'],
        datasets: [
          { label: 'Loan Sweep', data: [rep], backgroundColor: '#185FA5', borderRadius: 4 },
          { label: 'Dato Div', data: [datoDiv], backgroundColor: '#0B1C3F', borderRadius: 4 },
          { label: 'Foundry Div', data: [abcDiv], backgroundColor: '#B8944A', borderRadius: 4 }
        ]
      },
      options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, scales: { x: { stacked: true, display:false }, y: { stacked: true, display:false } } }
    });
  }
  document.querySelectorAll('#tab3 input').forEach(i => i.addEventListener('input', calcWaterfall));

  // --- TAB 4: SANDBOX ---
  function calcSandbox() {
    let b2b = v('sl-s4-b2b-vol');
    let b2c = v('sl-s4-b2c-vol');
    let medVol = b2b + b2c;
    let medSpend = v('sl-s4-med-spend');
    let medMargin = v('sl-s4-med-margin') / 100;
    let tvlPct = v('sl-s4-tvl-pct') / 100;
    let tvlSpend = v('sl-s4-tvl-spend');
    let tvlMargin = v('sl-s4-tvl-margin') / 100;
    let baseCac = v('sl-s4-cac');

    setT('val-s4-b2b-vol', b2b);
    setT('val-s4-b2c-vol', b2c);
    setT('val-s4-med-spend', 'RM ' + fmtK(medSpend));
    setT('val-s4-med-margin', (medMargin*100)+'%');
    setT('val-s4-tvl-pct', (tvlPct*100)+'%');
    setT('val-s4-tvl-spend', 'RM ' + fmtK(tvlSpend));
    setT('val-s4-tvl-margin', (tvlMargin*100)+'%');
    setT('val-s4-cac', 'RM ' + fmt(baseCac));
    
    let medNetPerPt = medSpend * medMargin;
    let tvlNetPerPkg = tvlSpend * tvlMargin;
    setT('hint-s4-med-net', 'RM ' + fmt(medNetPerPt) + ' / pt');

    let dynCac = Math.max(1500, baseCac - (Math.floor(medVol / 10) * 150));
    let totalCac = medVol * dynCac;
    let rev = (medVol * medNetPerPt) + (Math.round(medVol * tvlPct) * tvlNetPerPkg);
    let gp = rev - totalCac;

    setT('out-s4-rev', 'RM ' + fmt(rev));
    setT('out-s4-cac-total', 'RM ' + fmt(medVol > 0 ? totalCac/medVol : 0));
    setT('out-s4-gp', 'RM ' + fmt(gp));
    setT('out-s4-margin', rev > 0 ? (gp/rev*100).toFixed(1)+'%' : '0%');

    const mb = document.querySelector('#tab4 .master-box');
    if(mb) {
        if (gp < 0) { mb.style.background = 'var(--red-bg)'; mb.style.color = 'var(--red)'; }
        else { mb.style.background = 'var(--navy)'; mb.style.color = 'white'; }
    }

    if (!document.getElementById('tab4').classList.contains('active')) return;
    const ctx = document.getElementById('sandboxChart');
    if(!ctx) return;
    if(sandboxChart) sandboxChart.destroy();
    sandboxChart = new Chart(ctx.getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['Distribution'],
        datasets: [
          { label: 'CAC Costs', data: [rev>0 ? (totalCac/rev)*100 : 0], backgroundColor: '#A32D2D', borderRadius: 4 },
          { label: 'Gross Margin', data: [rev>0 ? (gp/rev)*100 : 0], backgroundColor: '#0F6E56', borderRadius: 4 }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, scales: { x: { stacked: true, display:false }, y: { stacked: true, max: 100 } } }
    });
  }
  document.querySelectorAll('#tab4 input').forEach(i => i.addEventListener('input', calcSandbox));

  // --- TAB 5: P&L SCENARIOS ---
  let currentScen = 'base';
  const SCENARIO_DATA = {
      bear: { ptsY5: 600, opexY5: 2500000 },
      base: { ptsY5: 1800, opexY5: 4000000 },
      bull: { ptsY5: 3500, opexY5: 6500000 }
  };

  function setScenario(scen, btn) {
      currentScen = scen;
      document.querySelectorAll('#scenario-toggles .dash-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      calcSim();
  }

  function calcSim() {
    let tdoxComm = v('s_tdox_comm') / 100;
    let abcFeeBase = v('s_abc_fee') / 100; // Terminal Rate
    
    setT('v_tdox_comm', (tdoxComm*100)+'%');
    setT('v_abc_fee', (abcFeeBase*100)+'%');

    const sd = SCENARIO_DATA[currentScen];
    const curves = { pts: [0.10, 0.25, 0.45, 0.70, 1.0], opex: [0.35, 0.45, 0.60, 0.80, 1.0] };
    
    // Explicit Management Fees based on new Market Rate Logic
    const MGMT_ANNUAL = [
      192000, // Y1: (6 mos @ 12k probation) + (6 mos @ 20k post-probation)
      360000, // Y2: 12 mos @ 30k (M2 scaling)
      600000, // Y3: 12 mos @ 50k (M3 confirmed)
      900000, // Y4: 12 mos @ 75k (M4 mature)
      1200000 // Y5: 12 mos @ 100k (M5 terminal rate)
    ];
    
    let d = { pts:[], rev:[], gp:[], foundryFee:[], foundryMgmt:[], ebitda:[], np:[], rep:[], foundryDiv:[], datoDiv:[], bal:[], eq:[] };
    let loanBal = 2410000;
    let cumRev = 0;
    let highestEq = 0.0; // Starts at 0% until RM 250K hit

    for(let i=0; i<5; i++) {
      let pts = Math.round(sd.ptsY5 * curves.pts[i]);
      let dynCac = Math.max(1500, 6000 - (Math.floor(pts / 10) * 150));
      
      let medRev = pts * 40000 * tdoxComm; 
      let tvlRev = Math.round(pts * 0.8) * 20000 * 0.30;
      let rev = medRev + tvlRev;
      cumRev += rev;
      
      let gp = rev - (pts * dynCac);
      
      // SUCCESS FEE LOGIC: Probation Discount applied to Year 1
      let currentFeeRate = abcFeeBase;
      if (i === 0) {
        // Y1 Blended Rate: (6 mos @ 20% probation + 6 mos @ 25% post-probation).
        // Assumes Terminal slider is set around 30%.
        currentFeeRate = Math.max(0, abcFeeBase - 0.075); 
      }
      if (i === 1) {
        currentFeeRate = Math.max(0, abcFeeBase - 0.05); // Y2 step up to 25% (if terminal is 30)
      }
      
      let currentFoundryFee = Math.max(0, gp * currentFeeRate);
      let mgmtFee = MGMT_ANNUAL[i];
      
      let opex = (sd.opexY5 * curves.opex[i]) + mgmtFee + currentFoundryFee;
      let ebitda = rev - (pts * dynCac) - opex; // Gross Profit - OPEX
      let np = ebitda > 0 ? ebitda * 0.76 : 0; // 24% tax

      // CUMULATIVE RATCHET LOGIC 
      let margin = rev > 0 ? ebitda/rev : 0;
      let yrEq = 0.0;
      if (cumRev >= 50000000) yrEq = 0.45;       // M5
      else if (cumRev >= 30000000) yrEq = 0.40;  // M4
      else if (cumRev >= 15000000 && margin >= 0.15) yrEq = 0.30; // M3
      else if (cumRev >= 5000000) yrEq = 0.20;   // M2
      else if (cumRev >= 250000) yrEq = 0.10;    // M1
      
      highestEq = Math.max(highestEq, yrEq);
      
      let rep = 0, pool = 0;
      if (np > 0 && loanBal > 0) { rep = Math.min(np * 0.65, loanBal); loanBal -= rep; }
      pool = np - rep;

      d.pts.push(pts); d.rev.push(rev); d.gp.push(gp); 
      d.foundryFee.push(currentFoundryFee); d.foundryMgmt.push(mgmtFee);
      d.ebitda.push(ebitda); d.np.push(np); d.rep.push(rep); 
      d.foundryDiv.push(pool * highestEq); d.datoDiv.push(pool * (1-highestEq));
      d.bal.push(loanBal); d.eq.push(highestEq);
    }

    const row = (label, arr, cls="", isPct=false) => {
        let tds = arr.map(val => `<td style="text-align:right; color:${(!isPct && val<0)?'var(--red)':''}">${isPct ? (val*100).toFixed(0)+'%' : (val<0 ? '('+fmtM(Math.abs(val))+')' : fmtM(val))}</td>`).join('');
        return `<tr class="${cls}"><td>${label}</td>${tds}</tr>`;
    };

    let html = `<tr><td>Total Patients</td>${d.pts.map(p => `<td style="text-align:right;">${fmt(p)}</td>`).join('')}</tr>`;
    html += row('Gross Retained Revenue', d.rev, 'total-row');
    html += row('Gross Profit (Post-CAC)', d.gp);
    html += row('Foundry Management Fee', d.foundryMgmt, 'sub-row');
    html += row('Foundry Success Fee', d.foundryFee, 'sub-row');
    html += row('EBITDA', d.ebitda, 'total-row');
    html += row('Net Profit (Post-Tax)', d.np);
    html += row('Active Foundry Equity %', d.eq, 'highlight-row', true);
    html += row('Loan Sweep (65% Capped)', d.rep, 'highlight-row');
    html += row('↳ Remaining Loan', d.bal, 'sub-row');
    html += row('Foundry Pro-Rata Div', d.foundryDiv);
    html += row('Dato Pro-Rata Div', d.datoDiv);

    const tbody = document.getElementById('pnl-body');
    if(tbody) tbody.innerHTML = html;

    setT('kpi-y5-rev', 'RM ' + fmtM(cumRev) + ' M');
    setT('kpi-y5-ev', 'RM ' + fmtM(Math.max(0, d.ebitda[4]*7)) + ' M');
    
    let datoTotalCash = d.rep.reduce((a,b)=>a+b,0) + d.datoDiv.reduce((a,b)=>a+b,0) + (Math.max(0, d.ebitda[4]*7) * (1-d.eq[4]));
    setT('kpi-dato-roi', (datoTotalCash/2410000).toFixed(1) + 'x');

    let capEl = document.getElementById('kpi-y5-cap');
    if(capEl) {
        if (cumRev >= 50000000) { capEl.innerText = "M5 Unicorn Cap Hit ✓"; capEl.style.color = "var(--teal)"; }
        else { capEl.innerText = `Misses M5 Cap by RM ${fmtM(50000000 - cumRev)}M`; capEl.style.color = "var(--red)"; }
    }

    if (!document.getElementById('tab5').classList.contains('active')) return;
    const ctx = document.getElementById('simChart');
    if(!ctx) return;
    if(simCh) simCh.destroy();
    simCh = new Chart(ctx.getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['Year 1', 'Year 2', 'Year 3', 'Year 4', 'Year 5'],
        datasets: [
          { label: 'Revenue', data: d.rev.map(v=>Math.round(v/1000)), backgroundColor: '#0B1C3F', borderRadius: 4 },
          { label: 'Foundry Success Fee', data: d.foundryFee.map(v=>Math.round(v/1000)), backgroundColor: '#B8944A', borderRadius: 4 },
          { type: 'line', label: 'EBITDA', data: d.ebitda.map(v=>Math.round(v/1000)), borderColor: '#0F6E56', backgroundColor: 'rgba(15,110,86,0.1)', fill: true, tension: 0.4 }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { callback: v => 'RM '+v+'k' } } } }
    });
  }
  document.querySelectorAll('#tab5 input').forEach(i => i.addEventListener('input', calcSim));

  // Initialize
  window.onload = () => { 
      calcWaterfall(); 
      calcSandbox(); 
      calcSim(); 
  };
</script>
</body>
</html>
