table.dt { width: 100%; border-collapse: collapse; font-size: 11px; min-width: 680px; }
table.dt th { background: var(--surface2); padding: 10px 12px; text-align: right; font-weight: 600; color: var(--t2); white-space: nowrap; font-family: 'DM Mono', monospace; font-size: 10px; border-bottom: .5px solid var(--border); }
