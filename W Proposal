.sidebar-header { padding: 30px 24px; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 10px; }
.sidebar-logo { font-family: 'DM Mono', monospace; font-size: 24px; font-weight: 600; color: var(--surface); letter-spacing: -1px; }
.sidebar-logo span { color: var(--gold-l); }
.sidebar-sub { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; font-family: 'DM Mono', monospace; }

.nav-links { display: flex; flex-direction: column; padding-bottom: 30px; }
.nav-links a { padding: 12px 24px; font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.6); text-decoration: none; border-left: 3px solid transparent; transition: all 0.2s ease; cursor: pointer; }
.nav-links a:hover { color: var(--surface); background: rgba(255,255,255,0.03); }
.nav-links a.active { color: var(--gold-l); font-weight: 600; background: rgba(255,255,255,0.05); border-left-color: var(--gold-l); }

/* ── MAIN CONTENT AREA ── */
.main-content { flex: 1; height: 100vh; overflow-y: auto; scroll-behavior: smooth; padding: 40px 40px 80px; }
.page { max-width: 1000px; margin: 0 auto; }
.tab-content { display: none; animation: fadeIn 0.4s ease; }
.tab-content.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* ── TYPOGRAPHY & CARDS ── */
.page-header { padding-bottom: 24px; margin-bottom: 24px; border-bottom: .5px solid var(--border); }
.eyebrow { font-family: 'DM Mono', monospace; font-size: 10px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
.page-title { font-size: 30px; font-weight: 600; line-height: 1.15; margin-bottom: 8px; color: var(--navy); }
.page-sub { font-size: 13px; color: var(--t2); max-width: 680px; line-height: 1.7; }

.card { background: var(--surface); border: .5px solid var(--border); border-radius: var(--rl); padding: 24px; margin-bottom: 20px; }
.card-title { font-size: 16px; font-weight: 600; color: var(--t1); margin-bottom: 16px; padding-bottom: 12px; border-bottom: .5px solid var(--border); display: flex; justify-content: space-between; align-items: center; }

.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.g3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

