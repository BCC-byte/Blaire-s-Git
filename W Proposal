.info-alert { border-left: 3px solid var(--blue); background: var(--blue-bg); color: var(--blue-t); padding: 12px 16px; font-size: 12px; line-height: 1.7; margin-bottom: 20px; border-radius: 0 var(--r) var(--r) 0; }
