.metric-label { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--t3); text-transform: uppercase; font-weight: 600; letter-spacing: .5px; margin-bottom: 4px; }
.metric-value { font-family: 'DM Mono', monospace; font-size: 24px; font-weight: 500; margin: 6px 0; color: var(--t1); line-height: 1.2;}
.metric-sub { font-size: 11px; color: var(--t2); margin-top: 4px; line-height: 1.5; }

.slider-group { margin-bottom: 16px; }
.slider-group label { display: flex; justify-content: space-between; font-weight: 500; font-size: 12px; margin-bottom: 8px; color: var(--t1); }
.slider-group label span:last-child { font-family: 'DM Mono', monospace; font-weight: 600; color: var(--navy); }
input[type=range] { width: 100%; accent-color: var(--gold); height: 4px; border-radius: 2px; outline: none; }

.master-box { background: var(--navy); color: white; padding: 24px; border-radius: var(--rl); text-align: center; border-bottom: 4px solid var(--gold); margin-top: 20px; }
