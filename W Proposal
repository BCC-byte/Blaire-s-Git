*{box-sizing:border-box;margin:0;padding:0}

/* ── APP LAYOUT ── */
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--t1); font-size: 13px; line-height: 1.6; display: flex; height: 100vh; overflow: hidden; }

/* ── LEFT SIDEBAR ── */
