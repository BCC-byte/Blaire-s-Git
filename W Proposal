table.dt tr.total-row td { font-weight: 600; border-top: 1px solid var(--border-md); border-bottom: 1px solid var(--border-md); background: var(--bg); color: var(--navy); }
table.dt tr.highlight-row td { background: var(--amber-bg); color: var(--amber-t); font-weight: 600; border-bottom: none; }

.chart-container { position: relative; height: 300px; width: 100%; margin-top: 20px; }

/* ── MILESTONES ── */
